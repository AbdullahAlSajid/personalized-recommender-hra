{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug backend from repo root",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "console": "integratedTerminal",
      "jinja": true
    }
  ]
}